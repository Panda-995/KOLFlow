{
  "name": "kolflow",
  "private": true,
  "version": "1.3.0",
  "license": "AGPL-3.0-only",
  "author": "熊猫不是猫QAQ",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "test": "tsx --test tests/regressions.test.ts",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "cap:init": "npx cap init KOLFlow com.kolflow.app",
    "cap:add": "npx cap add android",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open": "npx cap open android",
    "cap:run": "npm run build && npx cap run android",
    "cap:live": "npx cap run android --livereload --external"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "node-forge": "^1.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.16.0",
    "read-excel-file": "^9.0.10",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.5.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^6.4.2"
  },
  "overrides": {
    "path-to-regexp": "0.1.13",
    "picomatch": "4.0.4",
    "postcss": "8.5.15",
    "body-parser": "1.20.6",
    "brace-expansion": "5.0.7",
    "tar": "7.5.21"
  }
}
