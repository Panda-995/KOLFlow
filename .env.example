# ===== 环境配置 =====

# NODE_ENV: 运行环境
# 可选值：development, production
# 生产环境必须设置 JWT_SECRET
NODE_ENV="development"

# PORT: 服务端口
PORT=3000

# APP_URL: 应用访问地址
# 用于自引用链接和 API 端点
APP_URL="https://kolflow.example.com"

# VITE_APP_DOWNLOAD_URL: “关于”页面中的 Android APP 下载/更新链接
# 构建前可替换为本次发布的 APK 或 Release 页面
VITE_APP_DOWNLOAD_URL="https://github.com/Panda-995/KOLFlow/releases/latest"

# ===== 安全配置 =====

# JWT_SECRET: JWT 令牌加密密钥
# 生产环境必须设置！开发环境自动生成随机密钥
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production

# INVITE_CODE: 注册邀请码
# 用于验证用户注册权限
# 生产环境必须修改！
INVITE_CODE=your-invite-code-change-in-production

# CORS_ORIGIN: CORS允许的域名
# 生产环境配置具体域名，多个域名用逗号分隔
# 示例：* 或 https://your-domain.com 或 https://app.example.com,https://api.example.com
CORS_ORIGIN=*

# ENFORCE_HTTPS: 生产环境是否拒绝通过 HTTP 访问 API
# 合规发布必须保持为 true；本地 development 环境不受影响
ENFORCE_HTTPS=true

# TRUST_PROXY: 是否信任前一跳反向代理传递的 X-Forwarded-Proto
# 仅在容器前一跳为受控 HTTPS 反向代理时设为 1；直连部署保持 false
TRUST_PROXY=false

# ===== 数据存储 =====

# DATA_DIR: 数据存储目录
# SQLite 数据库和上传文件存储位置
DATA_DIR="./data"

# ===== 部署说明 =====
# 环境要求：Node.js >= 20.19.0 或 >= 22.12.0
# 原因：@vitejs/plugin-react@5.x 需要更高版本的 Node.js
